# =============================================================================
# USA site — production / process environment (copy to server, never commit real values)
# On VPS:   sudo cp env.production.example /var/www/skycashmere-usa/server/.env
#           chmod 600 /var/www/skycashmere-usa/server/.env
# systemd:  EnvironmentFile=/var/www/skycashmere-usa/server/.env
# PM2:      use env_file in ecosystem.config.cjs or `dotenv` path to this file
# =============================================================================

# --- Server
PORT=5000
NODE_ENV=production
# Public browser origin for CORS, cookies, redirects (no trailing slash)
CLIENT_URL=https://skycashmere.us
# Public base URL of this API (Stripe redirects, upload URLs). No /api/v1 suffix.
# Example if Nginx terminates TLS: https://server.skycashmere.us
SERVER_URL=https://server.skycashmere.us
API_URL=https://server.skycashmere.us

# --- Database (use strong auth; Atlas: mongodb+srv://...)
MONGODB_URI=mongodb+srv://skycashmere12_db_user:n04Yy19zGXUyd7VO@cluster0.uuyxakf.mongodb.net/?appName=Cluster0?authSource=admin

# --- JWT (generate long random strings, e.g. openssl rand -base64 48)
JWT_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARS_MINIMUM
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_32_PLUS_CHARS
JWT_EXPIRE=30d
JWT_REFRESH_EXPIRE=90d

# --- Local uploads on the VPS (absolute path recommended)
UPLOAD_PATH=/var/www/skycashmere-usa/uploads
# Production should use R2 (below). Only set true for emergency local disk (not recommended).
ALLOW_LOCAL_MEDIA_UPLOAD=false

# --- Cloudflare R2 + CDN (required for admin media uploads in production)
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY=REPLACE_ME
R2_SECRET_KEY=REPLACE_ME
CDN_URL=https://your-r2-public-or-cdn-domain.com

# --- Optional: 64-char hex for field encryption (else JWT_SECRET is used for key derivation)
# MEDIA_ENCRYPTION_KEY=

# --- Logging
LOG_LEVEL=info

# --- Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# Publishable key: also exposed to client via Admin settings; this env is a server fallback
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
# From Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Tabby (if you use Tabby)
# TABBY_WEBHOOK_SECRET=
